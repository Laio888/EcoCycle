@page
@model asp_presentacion.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EcoCycle - Iniciar sesión</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f9fafb; min-height: 100vh; }
        .eco-nav { display: flex; align-items: center; justify-content: space-between; padding: 16px 32px; background: white; border-bottom: 1px solid #e5e7eb; }
        .eco-logo { display: flex; align-items: center; gap: 8px; font-size: 16px; font-weight: 600; color: #111827; text-decoration: none; }
        .eco-logo-icon { width: 32px; height: 32px; background: #16a34a; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .nav-btns { display: flex; gap: 12px; }
        .btn-outline { padding: 8px 20px; border: 1px solid #d1d5db; border-radius: 8px; background: transparent; color: #374151; font-size: 14px; text-decoration: none; display: inline-block; }
        .btn-green { padding: 8px 20px; border: none; border-radius: 8px; background: #16a34a; color: white; font-size: 14px; font-weight: 500; text-decoration: none; display: inline-block; }
        .main { display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 65px); padding: 40px 16px; }
        .card { background: white; border-radius: 12px; border: 1px solid #e5e7eb; padding: 40px; width: 100%; max-width: 440px; }
        .form-title { font-size: 22px; font-weight: 600; color: #111827; margin-bottom: 6px; }
        .form-sub { font-size: 14px; color: #6b7280; margin-bottom: 28px; }
        .form-group { margin-bottom: 16px; }
        label { font-size: 13px; color: #374151; display: block; margin-bottom: 6px; font-weight: 500; }
        input[type=email], input[type=password] { width: 100%; padding: 10px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; background: white; color: #111827; }
        input:focus { outline: none; border-color: #16a34a; box-shadow: 0 0 0 3px rgba(22,163,74,0.1); }
        .forgot { font-size: 12px; color: #16a34a; text-align: right; margin-top: 6px; cursor: pointer; }
        .btn-full { width: 100%; padding: 11px; background: #16a34a; color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 500; cursor: pointer; margin-top: 8px; }
        .btn-full:hover { background: #15803d; }
        .error-box { background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 10px 14px; margin-bottom: 16px; font-size: 13px; color: #dc2626; }
        .blocked-box { background: #fffbeb; border: 1px solid #fcd34d; border-radius: 8px; padding: 10px 14px; margin-bottom: 16px; font-size: 13px; color: #b45309; }
        .link-text { font-size: 13px; color: #6b7280; margin-top: 20px; text-align: center; }
        .link-text a { color: #16a34a; font-weight: 500; text-decoration: none; }
    </style>
</head>
<body>
<nav class="eco-nav">
    <a href="/" class="eco-logo">
         <div class="w-10 h-10 bg-gradient-to-br 

            from-green-500 to-emerald-600 rounded-xl flex items-center justify-center" 
        data-fg-d4xe5="23.13:31.647:/src/app/pages/Landing.tsx:84:13:2338:192:e:div:e" 
        data-fgid-d4xe5=":r7:"><svg xmlns="http://www.w3.org/2000/svg" width="24"
        height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" 
        stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-leaf w-6 h-6 text-white"
        data-fg-d4xe6="23.13:31.647:/src/app/pages/Landing.tsx:85:15:2472:39:e:Leaf::::::Dxgq" 
        data-fgid-d4xe6=":r8:"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z">

      </path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg></div>
        EcoCycle
    </a>
    <div class="nav-btns">
       
        <a href="/Registro" class="btn-green">Registrarse</a>
    </div>
</nav>
<div class="main">
    <div class="card">
        <p class="form-title">Bienvenido de nuevo</p>


        @if (Model.CuentaBloqueada)
        {
            <div class="blocked-box">Tu cuenta ha sido bloqueada por múltiples intentos fallidos. Contacta al soporte.</div>
        }
        else if (Model.ErrorMessage != null)
        {
            <div class="error-box">@Model.ErrorMessage</div>
        }
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="correo">Correo electrónico</label>
                <input type="email" id="correo" name="correo" placeholder="tucorrreo@ejemplo.com" required />
            </div>
            <div class="form-group">
                <label for="contrasena">Contraseña</label>
                <input type="password" id="contrasena" name="contrasena" placeholder="••••••••" required />
                <p class="forgot">¿Olvidaste tu contraseña?</p>
            </div>
            <button type="submit" class="btn-full">Iniciar sesión</button>
        </form>
        <p class="link-text">¿No tienes cuenta? <a href="/Registro">Regístrate aquí</a></p>
    </div>
</div>
</body>
</html>
