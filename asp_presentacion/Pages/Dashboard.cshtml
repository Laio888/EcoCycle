@page
@model DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard Ambiental";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #f0fdf4 0%, #ffffff 60%);
        min-height: 100vh;
    }

    /* Navegación - Estilo consistente con Index */
    .eco-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 48px;
        background: white;
        border-bottom: 1px solid #e5e7eb;
    }

    .eco-logo {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        text-decoration: none;
    }

    .eco-logo-icon {
        width: 36px;
        height: 36px;
        background: #16a34a;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .nav-btns {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-outline {
        padding: 9px 22px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: transparent;
        color: #374151;
        font-size: 14px;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .btn-outline:hover {
        border-color: #16a34a;
        color: #16a34a;
        transform: translateY(-2px);
    }

    .btn-green {
        padding: 9px 22px;
        border: none;
        border-radius: 8px;
        background: #16a34a;
        color: white;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .btn-green:hover {
        background: #15803d;
        transform: translateY(-2px);
    }

    .btn-primary {
        padding: 9px 22px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    /* Contenedor principal */
    .dashboard-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px 48px;
    }

    /* Header */
    .dashboard-header {
        background: white;
        border-radius: 20px;
        padding: 25px 30px;
        margin-bottom: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #e5e7eb;
    }

    .dashboard-header h2 {
        margin: 0;
        color: #111827;
        font-size: 28px;
        font-weight: 800;
    }

    .dashboard-header p {
        margin: 8px 0 0 0;
        color: #6b7280;
        font-size: 14px;
    }

    /* Tarjetas KPI */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .kpi-card {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        border: 1px solid #e5e7eb;
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #16a34a, #15803d);
    }

    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }

    .kpi-label {
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        color: #6b7280;
        margin-bottom: 10px;
    }

    .kpi-value {
        font-size: 36px;
        font-weight: 800;
        margin: 10px 0;
        color: #111827;
    }

    .kpi-unit {
        font-size: 14px;
        color: #6b7280;
        margin-left: 5px;
    }

    .kpi-icon {
        font-size: 40px;
        opacity: 0.3;
        float: right;
    }

    /* Grid de gráficas */
    .charts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 25px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        transition: transform 0.3s ease;
        border: 1px solid #e5e7eb;
    }

    .chart-card:hover {
        transform: translateY(-3px);
    }

    .chart-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #f0fdf4;
    }

    canvas {
        max-height: 250px !important;
        width: 100% !important;
    }

    /* Tabla de historial */
    .history-section {
        background: white;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        border: 1px solid #e5e7eb;
    }

    .history-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f0fdf4;
        flex-wrap: wrap;
        gap: 15px;
    }

    .history-header h5 {
        font-size: 20px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .history-badge {
        background: #16a34a;
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .history-table {
        width: 100%;
        border-collapse: collapse;
    }

    .history-table thead {
        background: #f0fdf4;
        border-radius: 10px;
    }

    .history-table th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #374151;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .history-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
    }

    .history-table tbody tr:hover {
        background: #f0fdf4;
        transition: background 0.2s ease;
    }

    /* Badges de calidad */
    .quality-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .quality-high {
        background: #dcfce7;
        color: #166534;
    }

    .quality-medium {
        background: #fed7aa;
        color: #7c2d12;
    }

    .quality-low {
        background: #fee2e2;
        color: #991b1b;
    }

    /* Botón flotante para registro rápido */
    .fab {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #16a34a;
        color: white;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        cursor: pointer;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        transition: all 0.3s ease;
        text-decoration: none;
        z-index: 1000;
    }

    .fab:hover {
        transform: scale(1.1);
        background: #15803d;
        box-shadow: 0 8px 25px rgba(22, 163, 74, 0.4);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .eco-nav {
            flex-direction: column;
            gap: 16px;
            padding: 16px 20px;
        }

        .dashboard-container {
            padding: 20px;
        }

        .nav-btns {
            justify-content: center;
        }

        .kpi-value {
            font-size: 28px;
        }

        .charts-grid {
            grid-template-columns: 1fr;
        }

        .history-table th,
        .history-table td {
            padding: 8px 10px;
            font-size: 12px;
        }

        .fab {
            width: 50px;
            height: 50px;
            font-size: 24px;
            bottom: 20px;
            right: 20px;
        }
    }

    /* Animaciones */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .kpi-card, .chart-card, .history-section {
        animation: fadeInUp 0.6s ease-out;
    }
</style>

<!-- Barra de Navegación - Estilo consistente con Index -->
<nav class="eco-nav">
    <a href="/Index" class="eco-logo">
        <div class="eco-logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
            </svg>
        </div>
        EcoCycle
    </a>
    <div class="nav-btns">
        <a href="/Index" class="btn-outline">🏠 Inicio</a>
        <a href="/Recompensas" class="btn-primary">🎁 Recompensas</a>
        <a href="/RegistrarResiduos" class="btn-green">♻️ Registrar Residuos</a>
        <a href="/Aprender" class="btn-green" title="Aprender">📚</a>
        <a href="/Puntos" class="btn-primary" title="Puntos y Ranking">🏆</a>
    </div>
</nav>

<div class="dashboard-container">
    <!-- Header -->
    <div class="dashboard-header">
        <h2>📊 Dashboard Ambiental</h2>
        <p>Monitoreo de reciclaje y huella de carbono</p>
    </div>

    <!-- KPIs -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-icon">⭐</div>
            <div class="kpi-label">Puntos Acumulados</div>
            <div class="kpi-value">@Model.Puntos.ToString("N0")</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">🏆</div>
            <div class="kpi-label">Nivel Actual</div>
            <div class="kpi-value">@Model.Nivel</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">📊</div>
            <div class="kpi-label">Ranking Global</div>
            <div class="kpi-value">#@Model.Ranking</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-icon">🌍</div>
            <div class="kpi-label">CO₂ Evitado</div>
            <div class="kpi-value">@Model.CO2Reducido.ToString("F1") <span class="kpi-unit">kg</span></div>
        </div>
    </div>

    <!-- Gráficas -->
    <div class="charts-grid">
        <div class="chart-card">
            <div class="chart-title">
                ♻️ Kg Reciclados por Mes
            </div>
            <canvas id="kgChart"></canvas>
        </div>

        <div class="chart-card">
            <div class="chart-title">
                ⭐ Puntos por Mes
            </div>
            <canvas id="puntosChart"></canvas>
        </div>

        <div class="chart-card">
            <div class="chart-title">
                🌿 CO₂ Evitado por Mes
            </div>
            <canvas id="co2Chart"></canvas>
        </div>
    </div>

    <!-- Historial -->
    <div class="history-section">
        <div class="history-header">
            <h5>📋 Historial de Reciclaje</h5>
            <span class="history-badge">Últimos registros</span>
        </div>

        <table class="history-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Tipo de Material</th>
                    <th>Peso</th>
                    <th>Calidad</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Historial)
                {
                    <tr>
                        <td>@item.Fecha.ToString("dd MMM yyyy")</td>
                        <td>@item.Tipo</td>
                        <td><strong>@item.Peso.ToString("F1")</strong> kg</td>
                        <td>
                            @if (item.Calidad == "Alta")
                            {
                                <span class="quality-badge quality-high">🟢 Alta</span>
                            }
                            else if (item.Calidad == "Media")
                            {
                                <span class="quality-badge quality-medium">🟡 Media</span>
                            }
                            else
                            {
                                <span class="quality-badge quality-low">🔴 Baja</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Botón flotante para registro rápido -->
<a href="/RegistrarResiduos" class="fab" title="Registrar Residuos">
    ♻️
</a>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const meses = @Html.Raw(JsonSerializer.Serialize(Model.Meses));
        
        // Configuración común para todas las gráficas
        const chartOptions = {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'top',
                    labels: {
                        font: {
                            size: 12,
                            family: "'Segoe UI', sans-serif"
                        },
                        usePointStyle: true,
                        boxWidth: 6
                    }
                },
                tooltip: {
                    backgroundColor: 'rgba(0,0,0,0.8)',
                    padding: 10,
                    cornerRadius: 8,
                    titleFont: {
                        size: 13
                    },
                    bodyFont: {
                        size: 12
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: {
                        color: 'rgba(0,0,0,0.05)'
                    },
                    ticks: {
                        font: {
                            size: 11
                        }
                    }
                },
                x: {
                    grid: {
                        display: false
                    },
                    ticks: {
                        font: {
                            size: 11
                        }
                    }
                }
            }
        };

        // Gráfica de Kg
        new Chart(document.getElementById('kgChart'), {
            type: 'line',
            data: {
                labels: meses,
                datasets: [{
                    label: 'Kg Reciclados',
                    data: @Html.Raw(JsonSerializer.Serialize(Model.KgMensual)),
                    borderColor: '#16a34a',
                    backgroundColor: 'rgba(22, 163, 74, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    pointBackgroundColor: '#16a34a',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2
                }]
            },
            options: chartOptions
        });

        // Gráfica de Puntos
        new Chart(document.getElementById('puntosChart'), {
            type: 'line',
            data: {
                labels: meses,
                datasets: [{
                    label: 'Puntos',
                    data: @Html.Raw(JsonSerializer.Serialize(Model.PuntosMensual)),
                    borderColor: '#667eea',
                    backgroundColor: 'rgba(102, 126, 234, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    pointBackgroundColor: '#667eea',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2
                }]
            },
            options: chartOptions
        });

        // Gráfica de CO₂
        new Chart(document.getElementById('co2Chart'), {
            type: 'line',
            data: {
                labels: meses,
                datasets: [{
                    label: 'CO₂ Evitado (kg)',
                    data: @Html.Raw(JsonSerializer.Serialize(Model.CO2Mensual)),
                    borderColor: '#f97316',
                    backgroundColor: 'rgba(249, 115, 22, 0.1)',
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    pointBackgroundColor: '#f97316',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2
                }]
            },
            options: chartOptions
        });
    });
</script>